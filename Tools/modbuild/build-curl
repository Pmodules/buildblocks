#!/usr/bin/env modbuild

export LC_ALL=C

pbuild::post_configure(){
	find "${BUILD_DIR}" -name Makefile -exec sed -i -e 's/[[:space:]]-lpsl\($\|[[:space:]]\)/ -l:libpsl.a /g' {} \;
	find "${BUILD_DIR}" -name Makefile -exec sed -i -e 's/[[:space:]]-lz\($\|[[:space:]]\)/ -l:libz.a /g' {} \;
	find "${BUILD_DIR}" -name Makefile -exec sed -i -e 's/[[:space:]]-lssl\($\|[[:space:]]\)/ -l:libssl.a /g' {} \;
	find "${BUILD_DIR}" -name Makefile -exec sed -i -e 's/[[:space:]]-lcrypto\($\|[[:space:]]\)/ -l:libcrypto.a -ldl /g' {} \;
}

pbuild::post_install() {
	rm -rf "${PREFIX}/include"
	rm -rf "${PREFIX}/share/locale"
	rm -rf "${PREFIX}/share/doc"
	rm -rf "${PREFIX}/share/info"
	rm -rf "${PREFIX}/share/man/"
}
