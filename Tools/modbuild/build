#!/usr/bin/env modbuild

pbuild::configure() {
	:
}
pbuild::compile() {
	:
}

pbuild::install() {
	mkdir -p "${PREFIX}/bin"
	mkdir -p "${PREFIX}/lib"
	install --mode=0755 src/modbuild  "${PREFIX}/bin"
	install --mode=0755 src/lib*  "${PREFIX}/lib"
}

