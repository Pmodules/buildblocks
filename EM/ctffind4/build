#!/usr/bin/env modbuild

pbuild::pre_configure() {
    # For ARM CPUs, the matrix.cpp file needs to be modified to be compiled
    if [[ "$(uname -m)" == "aarch64" ]]; then
        cp ${BUILDBLOCK_DIR}/v${V_PKG}/src/core/matrix.cpp ${SRC_DIR}/src/core/matrix.cpp
    fi

    ####################
    # wxWidgets
    ####################
    cd "${BUILD_DIR}"
    : "${WXWIDGETS_VERSION:=3.2.10}"
    wget https://github.com/wxWidgets/wxWidgets/releases/download/v${WXWIDGETS_VERSION}/wxWidgets-${WXWIDGETS_VERSION}.tar.bz2
    bunzip2 wxWidgets-${WXWIDGETS_VERSION}.tar.bz2 
    tar xf wxWidgets-${WXWIDGETS_VERSION}.tar
    cd wxWidgets-${WXWIDGETS_VERSION}
    mkdir gtk-build
    cd gtk-build
    ../configure --prefix=${PREFIX}
    make -j 8
    make install
}

pbuild::configure() {
    ${SRC_DIR}/configure --with-wx-config=${PREFIX}/bin/wx-config --prefix=${PREFIX}
}

