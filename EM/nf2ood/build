#!/usr/bin/env modbuild

pbuild::prep() {
    mkdir -p ${PREFIX}/${P}-download

    wget -O "$PREFIX/${P}-download/${P}-${V_PKG}.tar.gz" \
    "https://github.com/TuftsRT/nfcore2ood/archive/refs/tags/v${V_PKG}.tar.gz"

    # Extract the downloaded package
    tar -xzf "$PREFIX/${P}-download/${P}-${V_PKG}.tar.gz" \
    --strip-components=1 \
    -C "$PREFIX"

    # Remove the ${P}-download directory
    rm -r "$PREFIX/${P}-download"
}

pbuild::configure() {
    :
}

pbuild::compile() {
    :
}

pbuild::install() {
    :
}
