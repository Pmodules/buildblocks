#!/usr/bin/env modbuild

# default Python version
: "${PYTHON_VERSION:=3.11}"

pbuild::prep() {
    git clone https://github.com/kuixu/ResMap "$SRC_DIR" || return $?
}

pbuild::configure() {
    # Install Miniforge
    mkdir -p "$PREFIX/miniforge"
    wget "https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-$(uname)-$(uname -m).sh" -O "$PREFIX/miniforge/miniforge.sh"
    bash "$PREFIX/miniforge/miniforge.sh" -b -u -p "$PREFIX/miniforge/"

    # Initialize mamba for script use
    source "$PREFIX/miniforge/etc/profile.d/mamba.sh"

    # Create the conda environment
    mamba create -y --name "${P}_${V_PKG}" "python=${PYTHON_VERSION}"
}

pbuild::compile() {
    :
}

pbuild::install() {
    # Ensure mamba is initialized
    source "$PREFIX/miniforge/etc/profile.d/mamba.sh"

    # Activate the conda environment
    mamba activate "${P}_${V_PKG}"

    # Set the source directory
    cd "$SRC_DIR"

    # Remove __init__.py if exists because it will not allow to create an
    # executable
    [ -f "__init__.py" ] && rm "__init__.py"

    # Install dependencies
    pip install numpy scipy matplotlib pyinstaller

    # Build the executable
    pyinstaller -F ResMap.py

    # Create a bin directory in PREFIX
    mkdir "$PREFIX/bin"

    # Copy the executable to $PREFIX/bin
    cp ./dist/ResMap "$PREFIX/bin"
}

