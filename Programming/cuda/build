#!/usr/bin/env modbuild

pbuild::install() {
	bash ./cuda_${V_PKG}_linux_$(arch).run --silent --toolkit --toolkitpath=${PREFIX} --no-opengl-libs --no-man-page
}

pbuild::post_install() {
	cd "${PREFIX}/lib64/stubs"
	for lib in lib*; do
		local soname="$(patchelf --print-soname "${lib}" 2>/dev/null)" || continue
		if [[ ! -e "${soname}" ]]; then
			ln -s "${lib}" "${soname}"
		fi
	done
}
