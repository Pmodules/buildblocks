#!/usr/bin/env modbuild

declare bootstrap_flags=''

pbuild::pre_configure() {
	bootstrap_flags+='--system-curl'
}

pbuild::configure() {
	"${SRC_DIR}/bootstrap" --prefix="${PREFIX}" ${bootstrap_flags} --verbose
}

pbuild::post_install() {
	local -r libdir="${PREFIX}/.lib"
	local -r gcc_libdir="${GCC_DIR}/lib64"
	mkdir -p "${libdir}"
	cp -v \
		"${gcc_libdir}"/libgcc_s.so.* \
		"${gcc_libdir}"/libstdc++.so.* \
		"${libdir}"
	while read bin; do
		patchelf --set-rpath '$ORIGIN/../.lib' --force-rpath "${bin}"
	done < <(grep -rl -a -m1 $'^\x7f\x45\x4c\x46' "${PREFIX}/bin")
}
